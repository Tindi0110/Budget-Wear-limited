datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String
  name       String
  role       String    @default("CUSTOMER") // "SUPERADMIN", "BRANCH_ADMIN", "BRANCH_STAFF", "CUSTOMER"
  created_at DateTime  @default(now())

  branch_id  String?
  branch     Branch?   @relation(fields: [branch_id], references: [id])
  orders     Order[]
}

model Branch {
  id         String    @id @default(uuid())
  name       String
  location   String
  type       String    // "thrift_store" or "baby_shop"
  created_at DateTime  @default(now())
  
  products   Product[]
  orders     Order[]
  staff      User[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  icon     String?
  products Product[]
}

model Product {
  id          String         @id @default(uuid())
  name        String
  price       Float
  description String
  stock       Int            @default(0)
  created_at  DateTime       @default(now())
  
  branch_id   String
  branch      Branch         @relation(fields: [branch_id], references: [id])
  
  category_id String
  category    Category       @relation(fields: [category_id], references: [id])
  
  images      ProductImage[]
  wishlists   Wishlist[]
  order_items OrderItem[]
}

model ProductImage {
  id         String   @id @default(uuid())
  product_id String
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  image_url  String
  position   Int      @default(0)
}

model Order {
  id            String      @id @default(uuid())
  customer_name String?
  total         Float
  status        String      @default("PENDING")
  created_at    DateTime    @default(now())
  
  branch_id     String
  branch        Branch      @relation(fields: [branch_id], references: [id])

  user_id       String?
  user          User?       @relation(fields: [user_id], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid())
  order_id   String
  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product_id String
  product    Product  @relation(fields: [product_id], references: [id])
  quantity   Int
  price      Float    // Price at time of purchase
}

model Wishlist {
  id         String   @id @default(uuid())
  user_id    String   // Simulated user ID for MVP
  product_id String
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
}
